# Anthropic API key — used by the CopilotKit runtime route to talk to Claude.
ANTHROPIC_API_KEY=

# Optional GitHub PAT — only needed if the demo hits the 60 req/hr anonymous limit.
GITHUB_TOKEN=

# Public URL of the deploy worker. Set after `wrangler deploy` from workers/deploy/.
# Example: https://reporadar-deploy.<account>.workers.dev
NEXT_PUBLIC_DEPLOY_WORKER_URL=
