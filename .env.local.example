# Gemini API key — used by the CopilotKit runtime + the /api/deploy route.
# Sponsored by Google DeepMind for the hackathon ($25 in tokens).
GOOGLE_API_KEY=

# Optional override (default: gemini-2.5-flash)
GEMINI_MODEL=

# Optional GitHub PAT — only needed if the demo hits the 60 req/hr anonymous limit.
GITHUB_TOKEN=

# Optional: if set, /api/deploy forwards surface persistence to the Cloudflare worker
# instead of storing in process memory. Use this once reporadar-deploy is deployed.
NEXT_PUBLIC_DEPLOY_WORKER_URL=
DEPLOY_WORKER_URL=

# Auth WIP — required before enabling account access in production.
# Generate AUTH_SECRET with: openssl rand -base64 32
AUTH_SECRET=
AUTH_URL=http://localhost:3000
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
